# ============================================================
# ClusterLLM - Multi-Model Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# Only fill in the provider(s) you plan to use.
# ============================================================

# Which provider to use: openai | deepseek | qwen | llama
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=your-openai-key-here

# --- DeepSeek ---
# DEEPSEEK_API_KEY=your-deepseek-key-here

# --- Qwen (Alibaba DashScope) ---
# QWEN_API_KEY=your-qwen-key-here

# --- Llama (via Together AI) ---
# TOGETHER_API_KEY=your-together-key-here

# ============================================================
# Optional overrides (uncomment to customize)
# ============================================================
# LLM_API_KEY=         # Override any provider-specific key above
# LLM_BASE_URL=        # Override default base URL for the provider
# LLM_MODEL=           # Override default model name
